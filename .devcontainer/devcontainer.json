{
  // Development Container Configuration
  // This file configures the development environment for GitHub Codespaces and VS Code Dev Containers
  // It provides a consistent, reproducible development environment across all contributors

  // Base image: Microsoft's universal development container
  // This image includes common development tools, runtimes, and utilities
  // Version 2 includes: Node.js, Python, Java, .NET, Ruby, Go, PHP, and more
  // See: https://github.com/devcontainers/images/tree/main/src/universal
  "image": "mcr.microsoft.com/devcontainers/universal:2",

  // Features: Additional tools and runtimes to install in the container
  // Currently empty - the universal image provides most needed tools
  // Add features here if additional tools are required, e.g.:
  // "features": {
  //   "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  // }
  "features": {}
}
